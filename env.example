BOT_TOKEN=COLOQUE_O_TOKEN_DO_BOTFATHER
ADMIN_ID=SEU_ID_DO_TELEGRAM
VIP_LINK=https://t.me/+SEU_LINK_DO_CANAL_PRIVADO
SUPPORT_USERNAME=@seusuporte

SUNIZE_API_KEY=SUA_API_KEY
SUNIZE_API_SECRET=SUA_API_SECRET
SUNIZE_BASE_URL=https://api.sunize.com.br/v1

# Dados padrão usados para criar cobrança na Sunize
# Use apenas dados autorizados e válidos. CPF inválido pode fazer a Sunize recusar.
DEFAULT_CUSTOMER_NAME=Julia Costa
DEFAULT_CUSTOMER_EMAIL=juliacosta@gmail.com
DEFAULT_CUSTOMER_DOCUMENT=12345678910
# Se preencher o telefone abaixo, o bot não pergunta telefone ao cliente.
# Se deixar vazio, ele pergunta o telefone antes de gerar o Pix.
DEFAULT_CUSTOMER_PHONE=

# Railway fornece PORT automaticamente
PORT=8000

# Coloque uma senha forte e configure no webhook se quiser validar manualmente
WEBHOOK_SECRET=troque-essa-senha

# Banco: no Railway, adicione PostgreSQL e ele cria DATABASE_URL automaticamente.
# Localmente, se vazio, usa sqlite app.db.
DATABASE_URL=

# Mídias locais. Coloque sua foto em media/start.jpg e vídeo em media/start.mp4
START_PHOTO_PATH=media/start.jpg
START_VIDEO_PATH=media/start.mp4
